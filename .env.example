# Public site URL (used by sitemap, canonicals, OG tags)
NEXT_PUBLIC_SITE_URL=https://rassoul.org

# Anthropic API key — needed for the weekly content generator
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# sunnah.com API key — free at https://sunnah.com/developers
# If omitted, the generator falls back to citing search URLs (less ideal).
SUNNAH_API_KEY=

# Override the default model (claude-opus-4-7)
# CLAUDE_MODEL=claude-sonnet-4-6

# How many posts to generate per weekly run (default 2)
# POSTS_PER_RUN=2
