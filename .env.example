# =============================================================================
# Local dev only — production values are set as Cloudflare Pages secrets
# via `wrangler pages secret put <NAME> --project-name=rassoul`
# =============================================================================

NEXT_PUBLIC_SITE_URL=https://rassoul.org

# ---- Bearer token that /api/admin/* requires ----
# Generate: openssl rand -base64 48
ADMIN_TOKEN=

# ---- LLM ----
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ---- Chatbot RAG (free, https://sunnah.com/developers) ----
SUNNAH_API_KEY=

# ---- Rate limit + donor sessions ----
# Free tier at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 32+ chars, sign donor cookies (openssl rand -base64 48)
DONOR_COOKIE_SECRET=

# ---- Stripe donate flow ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
