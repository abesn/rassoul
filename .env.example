# =============================================================================
# Required for the site to build
# =============================================================================
NEXT_PUBLIC_SITE_URL=https://rassoul.org

# =============================================================================
# LLM — DeepSeek powers the chatbot (content generation lives in n8n)
# =============================================================================
# Get a key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat    # default. Use "deepseek-reasoner" for R1.

# =============================================================================
# Chatbot RAG — optional but recommended (https://sunnah.com/developers)
# =============================================================================
SUNNAH_API_KEY=

# =============================================================================
# Required for the chat assistant (app/api/chat)
# =============================================================================

# Upstash Redis — used for rate limiting (5 q/day per IP) AND for storing
# donor session_ids so /api/donate/verify can mint a donor cookie.
# Get free creds at https://console.upstash.com (create a Redis DB → REST tab)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Random 32+ char string. Sign donor JWT cookies. Treat like a password.
# Generate one with:  openssl rand -base64 48
DONOR_COOKIE_SECRET=

# Free daily question budget for non-donors (default 5)
# CHAT_FREE_DAILY_LIMIT=5

# Set to 1 to make the chat widget visible to everyone.
# When unset, soft-launch mode: visible only via ?chat=1 query param.
# NEXT_PUBLIC_CHAT_PUBLIC=1

# =============================================================================
# Stripe — for the donate-for-unlimited flow
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Webhook setup:
#   1. Deploy the site.
#   2. In Stripe Dashboard → Developers → Webhooks → Add endpoint
#      URL:     https://rassoul.org/api/donate/webhook
#      Events:  checkout.session.completed
#   3. Copy the signing secret into STRIPE_WEBHOOK_SECRET above.
